<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DefectModify</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DefectModify.styles.css" asp-append-version="true" />
    <style>
        .navbar { background: #fff !important; border-bottom: 2px solid #D4E6DC !important; }
        .navbar-brand { color: #3E7A5E !important; font-weight: 800; font-size: 1.1rem; letter-spacing: -.01em; }
        .nav-link { color: #4A5568 !important; font-weight: 500; font-size: .9rem; border-radius: 7px; transition: background .15s, color .15s; }
        .nav-link:hover { color: #3E7A5E !important; background: #EFF7F3 !important; }
        .nav-link.active-page { color: #3E7A5E !important; font-weight: 700; }
        .nav-divider { width: 1px; background: #D4E6DC; margin: 0 .25rem; height: 1.5rem; align-self: center; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm box-shadow mb-3 px-2">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    🔧 DefectModify
                </a>
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">🏠 Home</a>
                        </li>
                        <li class="d-none d-sm-flex nav-divider"></li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Defect" asp-action="Modify">⚙️ Sửa đổi dữ liệu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Defect" asp-action="Log">📋 Lịch sử thay đổi</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-3 px-md-4">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-2">
        <div class="container-fluid px-3 px-md-4 py-2" style="font-size:.82rem">
            &copy; 2026 - DefectModify
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
